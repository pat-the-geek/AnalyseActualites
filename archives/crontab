SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin

# Surveillance round-robin des flux RSS WUDD.opml : 1 flux par exécution, toutes les 5 minutes
# Maintient 48-heures.json à jour de façon incrémentale (+ élagage articles > 48h)
*/5 * * * * root cd /app && python3 scripts/flux_watcher.py 2>&1 | tee -a /app/rapports/cron_flux_watcher.log
# Exécution de get-keyword-from-rss.py toutes les 2h de 6h00 à 22h00 (6,8,10,12,14,16,18,20,22)
# (reconstruit 48-heures.json intégralement — filet de sécurité + enrichissement sur toute la fenêtre 7j)
0 6-22/2 * * * root cd /app && python3 scripts/get-keyword-from-rss.py 2>&1 | tee -a /app/rapports/cron_get_keyword.log
# Vérification automatique du cron toutes les 10 minutes
*/10 * * * * root cd /app && python3 scripts/check_cron_health.py 2>&1 | tee -a /app/rapports/cron_health.log
# Exécute le scheduler chaque lundi à 6h du matin
0 6 * * 1 root cd /app && python3 scripts/scheduler_articles.py 2>&1 | tee -a /app/rapports/cron_scheduler.log
# Génère le radar thématique le dernier jour du mois à 5h00
0 5 28-31 * * root [ "$(date -d tomorrow +\%d)" = "01" ] && cd /app && python3 scripts/radar_wudd.py 2>&1 | tee -a /app/rapports/cron_radar.log
# Convertit les articles-from-rss en Markdown (nouveau format) le dernier jour du mois à 5h30
30 5 28-31 * * root [ "$(date -d tomorrow +\%d)" = "01" ] && cd /app && python3 scripts/articles_rss_to_markdown.py 2>&1 | tee -a /app/rapports/cron_rss_markdown.log
# Génère le rapport quotidien Top 10 entités des 48h à 23h00 (après la dernière collecte RSS de 22h00)
0 23 * * * root cd /app && python3 scripts/generate_48h_report.py 2>&1 | tee -a /app/rapports/cron_48h_report.log
# Détecte les tendances et génère data/alertes.json chaque matín à 7h00
0 7 * * * root cd /app && python3 scripts/trend_detector.py 2>&1 | tee -a /app/rapports/cron_trends.log
# Enrichissement sentiment Round-Robin : 1 fichier/source par jour à 3h00
# Tourne sur tous les fichiers data/articles/ et data/articles-from-rss/ de façon cyclique
0 3 * * * root cd /app && python3 scripts/enrich_sentiment.py 2>&1 | tee -a /app/rapports/cron_sentiment.log
# Enrichissement du temps de lecture chaque dimanche à 4h30 (calcul local, aucun appel EurIA)
# Ajoute temps_lecture_minutes/label à tous les articles data/articles/ et data/articles-from-rss/
30 4 * * 0 root cd /app && python3 scripts/enrich_reading_time.py 2>&1 | tee -a /app/rapports/cron_reading_time.log
# Analyse croisée des flux chaque lundi à 5h30, avant le scheduler hebdomadaire (6h00)
# Détecte les entités présentes dans ≥ 2 flux distincts → data/cross_flux_report.json
30 5 * * 1 root cd /app && python3 scripts/cross_flux_analysis.py 2>&1 | tee -a /app/rapports/cron_cross_flux.log
# Chronologie des entités : mise à jour quotidienne à 7h30, après trend_detector (7h00)
# Pré-calcule data/entity_timeline.json pour le tableau de bord (cache 1h via Flask)
30 7 * * * root cd /app && python3 scripts/entity_timeline.py 2>&1 | tee -a /app/rapports/cron_entity_timeline.log

