# ==============================================================================
# Configuration pour l'analyse d'actualités - TEMPLATE
# ==============================================================================
# 
# Instructions :
# 1. Copier ce fichier en .env : cp .env.example .env
# 2. Remplacer les valeurs d'exemple par vos vraies credentials
# 3. Ne JAMAIS commiter le fichier .env sur GitHub !
#
# ==============================================================================

# Fournisseur IA actif : "euria" (défaut) ou "claude"
AI_PROVIDER=euria

# Configuration API Infomaniak EurIA (Qwen3) — requis si AI_PROVIDER=euria
# --------------------------------------------------------------------------
# Endpoint de l'API d'intelligence artificielle Infomaniak (compatible OpenAI)
# Par défaut pour EurIA : https://api.infomaniak.com/2/ai/VOTRE_ID/openai/v1/chat/completions
URL=https://api.infomaniak.com/2/ai/VOTRE_PRODUCT_ID/openai/v1/chat/completions

# Token d'authentification Bearer pour l'API EurIA
# Obtenir depuis : Manager Infomaniak > Produits IA > API
bearer=VOTRE_TOKEN_BEARER_ICI

# Configuration API Anthropic Claude — requis si AI_PROVIDER=claude
# -----------------------------------------------------------------
# Clé API Anthropic (obtenir sur https://console.anthropic.com)
ANTHROPIC_API_KEY=
# Modèle pour les tâches batch (résumé, NER, sentiment) — par défaut Haiku
CLAUDE_MODEL_BATCH=claude-haiku-4-5-20251001
# Modèle pour les synthèses user-facing (rapport, RAG, encyclopédique) — par défaut Sonnet
CLAUDE_MODEL_SYNTHESIS=claude-sonnet-4-6

# Paramètres de gestion d'erreurs
# --------------------------------
# Nombre maximal de tentatives en cas d'échec de requête API
MAX_RETRIES=3

# Timeout pour les requêtes API (en secondes)
TIMEOUT_RESUME=60
TIMEOUT_RAPPORT=300

# ==============================================================================
# Nouvelles fonctionnalités v2.2 — Exports et notifications
# ==============================================================================

# Newsletter SMTP (optionnel — laisser vide pour désactiver)
# -----------------------------------------------------------
# Exemple avec Gmail : SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# Webhooks sortants (optionnel — laisser vide pour désactiver)
# -------------------------------------------------------------
# Discord : URL du webhook (Paramètres serveur > Intégrations > Webhooks)
WEBHOOK_DISCORD=

# Slack : URL du webhook entrant (api.slack.com > Incoming Webhooks)
WEBHOOK_SLACK=

# Ntfy.sh : URL de notification push (ex: https://ntfy.sh/votre-topic)
NTFY_URL=
# Token Ntfy si votre topic est privé (laisser vide si public)
NTFY_TOKEN=
